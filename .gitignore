# Build artifacts
/bin/
/ahsir
/ahsir-agent

# Plugin per-platform binaries — built by `make plugin`.
#
# These ARE tracked: they're the payload shipped to anyone installing the
# plugin via the marketplace (`/plugin install ahsir@ahsir`). Without them,
# marketplace consumers would have to clone the repo and rebuild — which
# defeats the point of marketplace install. Each binary is ~19 MB × 4 OS/
# arch × 2 (ahsir + ahsir-agent) ≈ 150 MB at the working tree; only one set
# of new objects per release commit gets added to git history.
#
# Refresh the commit after a release-worthy code change:
#   make plugin && git add plugin/bin && git commit
#
# If repo size ever becomes a real problem, the alternative is moving these
# to GitHub Releases + a download-on-first-use bin/ahsir wrapper. Not yet
# justified for this codebase.


# Vendored deps — fetched via `go mod download` instead
/vendor/

# Local agent-tool config — machine-specific (absolute paths, per-user
# settings), generated by the Codex / Claude Code dev loop. The shipped
# plugin manifest lives in .claude-plugin/, which IS tracked.
/.codex/
/.agents/
/.claude/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Runtime state generated by ahsir-agent (contextID → sessionID persistence).
# Auto-recreated on first request, contains per-environment ids that don't
# belong in version control.
**/.a2a/sessions.json
