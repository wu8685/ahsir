# Build artifacts
/bin/
/ahsir
/ahsir-agent

# Plugin per-platform binaries — built by `make plugin` / `make plugin-current`.
# Wrappers and metadata (plugin/.claude-plugin/, plugin/skills/, plugin/bin/*ahsir*
# at top level) are tracked; per-platform binary subdirs are not.
/plugin/bin/*/


# Vendored deps — fetched via `go mod download` instead
/vendor/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Runtime state generated by ahsir-agent (contextID → sessionID persistence).
# Auto-recreated on first request, contains per-environment ids that don't
# belong in version control.
**/.a2a/sessions.json
